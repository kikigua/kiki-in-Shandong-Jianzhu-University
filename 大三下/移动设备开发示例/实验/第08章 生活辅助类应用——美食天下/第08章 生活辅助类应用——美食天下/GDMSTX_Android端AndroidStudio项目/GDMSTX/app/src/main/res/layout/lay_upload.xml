<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/lay_upload"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginLeft="5dip"
    android:layout_marginRight="5dip"
    android:orientation="vertical"
    tools:context=".UploadRandom" >

    <include
        android:id="@+id/include_head"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        layout="@layout/head_general" />

    <ScrollView
        android:id="@+id/lay_upload_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" >

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dip"
            android:orientation="vertical" >

            <!-- 主图 -->

            <RelativeLayout
                android:id="@+id/layout_image"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dip"
                android:orientation="vertical" >

                <ImageView
                    android:id="@+id/main_image"
                    android:layout_width="fill_parent"
                    android:layout_height="202.0dip"
                    android:layout_marginLeft="20.0dip"
                    android:layout_marginRight="20.0dip"
                    android:layout_marginTop="15.0dip"
                    android:scaleType="centerCrop"
                    android:src="@drawable/recipe_defult_img" />

                <TextView
                    android:id="@+id/textView1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignBottom="@+id/main_image"
                    android:layout_alignRight="@+id/main_image"
                    android:background="#ff000000"
                    android:text="点击选择主图"
                    android:textColor="#ffffffff"
                    android:textSize="15sp" />
            </RelativeLayout>
            <!-- 菜谱名称 -->

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dip"
                android:ems="10"
                android:hint="菜谱名称"
                android:padding="10dip"
                android:textSize="15sp" >
            </EditText>
            <!-- 主食 -->

            <TextView
                android:id="@+id/food_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dip"
                android:text="主食"
                android:textSize="20sp" />

            <LinearLayout
                android:id="@+id/food_listview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >

                <LinearLayout
                    android:id="@+id/food_add"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dip"
                    android:orientation="vertical" >
                </LinearLayout>

                <include
                    android:id="@+id/include_food"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dip"
                    layout="@layout/menu_food_item" />
            </LinearLayout>

            <!-- 辅料 -->

            <TextView
                android:id="@+id/vice_tip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dip"
                android:text="辅料"
                android:textSize="20sp" />

            <LinearLayout
                android:id="@+id/vice_listview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >

                <LinearLayout
                    android:id="@+id/vice_add"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" >
                </LinearLayout>

                <include
                    android:id="@+id/include_vice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dip"
                    layout="@layout/menu_food_item" />
            </LinearLayout>

            <!-- 菜谱相关信息 -->

            <LinearLayout
                android:id="@+id/linear_choose"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dip"
                android:layout_marginTop="20dp"
                android:divider="@drawable/item_background"
                android:orientation="vertical"
                android:showDividers="beginning|middle|end" >

                <!-- 菜系 -->

                <RelativeLayout
                    android:id="@+id/lay_recipe_upload_caixi"
                    android:layout_width="fill_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="15.0dip"
                    android:layout_marginRight="15.0dip" >

                    <TextView
                        android:id="@+id/lay_recipe_upload_temp"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:text="菜   系"
                        android:textColor="#ff666666" />

                    <View
                        android:id="@+id/lay_recipe_upload_temp_0"
                        android:layout_width="1dip"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="10.0dip"
                        android:layout_marginRight="10.0dip"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp"
                        android:background="@color/gray" />

                    <TextView
                        android:id="@+id/lay_recipe_upload_caixi_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_0"
                        android:textColor="#ff666666" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/youjiantou" />
                </RelativeLayout>
                <!-- 菜谱口味 -->

                <RelativeLayout
                    android:id="@+id/lay_recipe_upload_kouwei"
                    android:layout_width="fill_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="15.0dip"
                    android:layout_marginRight="15.0dip" >

                    <TextView
                        android:id="@+id/lay_recipe_upload_temp_1"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:text="菜品口味"
                        android:textColor="#ff666666" />

                    <View
                        android:id="@+id/lay_recipe_upload_temp_2"
                        android:layout_width="1dip"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="10.0dip"
                        android:layout_marginRight="10.0dip"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_1"
                        android:background="@color/gray" />

                    <TextView
                        android:id="@+id/lay_recipe_upload_kouwei_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_2"
                        android:textColor="#ff666666" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/youjiantou" />
                </RelativeLayout>
                <!-- 烹饪方式 -->

                <RelativeLayout
                    android:id="@+id/lay_recipe_upload_pengren_fangshi"
                    android:layout_width="fill_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="15.0dip"
                    android:layout_marginRight="15.0dip" >

                    <TextView
                        android:id="@+id/lay_recipe_upload_temp_3"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:text="烹饪方式"
                        android:textColor="#ff666666" />

                    <View
                        android:id="@+id/lay_recipe_upload_temp_4"
                        android:layout_width="1dip"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="10.0dip"
                        android:layout_marginRight="10.0dip"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_3"
                        android:background="@color/gray" />

                    <TextView
                        android:id="@+id/lay_recipe_upload_pengren_fangshi_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_4"
                        android:textColor="#ff666666" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/youjiantou" />
                </RelativeLayout>
                <!-- 烹饪时间 -->

                <RelativeLayout
                    android:id="@+id/lay_recipe_upload_pengren_shijian"
                    android:layout_width="fill_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="15.0dip"
                    android:layout_marginRight="15.0dip" >

                    <TextView
                        android:id="@+id/lay_recipe_upload_temp_6"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:text="烹饪时间"
                        android:textColor="#ff666666" />

                    <View
                        android:id="@+id/lay_recipe_upload_temp_7"
                        android:layout_width="1dip"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="10.0dip"
                        android:layout_marginRight="10.0dip"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_6"
                        android:background="@color/gray" />

                    <TextView
                        android:id="@+id/lay_recipe_upload_pengren_shijian_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_7"
                        android:textColor="#ff666666" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/youjiantou" />
                </RelativeLayout>
                <!-- 主要厨具 -->

                <RelativeLayout
                    android:id="@+id/lay_recipe_upload_zhuyao_chuju"
                    android:layout_width="fill_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="15.0dip"
                    android:layout_marginRight="15.0dip" >

                    <TextView
                        android:id="@+id/lay_recipe_upload_temp_tool"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:text="主要厨具"
                        android:textColor="#ff666666" />

                    <View
                        android:id="@+id/lay_recipe_upload_temp_9"
                        android:layout_width="1dip"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="10.0dip"
                        android:layout_marginRight="10.0dip"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_tool"
                        android:background="@color/gray" />

                    <TextView
                        android:id="@+id/lay_recipe_upload_zhuyao_chuju_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_9"
                        android:textColor="#ff666666" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/youjiantou" />
                </RelativeLayout>
                <!-- 制作难度 -->

                <RelativeLayout
                    android:id="@+id/lay_recipe_upload_zhizuo_nandu"
                    android:layout_width="fill_parent"
                    android:layout_height="40dp"
                    android:layout_marginLeft="15.0dip"
                    android:layout_marginRight="15.0dip" >

                    <TextView
                        android:id="@+id/lay_recipe_upload_temp_8"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:text="制作难度"
                        android:textColor="#ff666666" />

                    <View
                        android:id="@+id/lay_recipe_upload_temp_9"
                        android:layout_width="1dip"
                        android:layout_height="20dp"
                        android:layout_centerVertical="true"
                        android:layout_marginLeft="10.0dip"
                        android:layout_marginRight="10.0dip"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_8"
                        android:background="@color/gray" />

                    <TextView
                        android:id="@+id/lay_recipe_upload_zhuyao_nandu_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toRightOf="@+id/lay_recipe_upload_temp_9"
                        android:textColor="#ff666666" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/youjiantou" />
                </RelativeLayout>
            </LinearLayout>
            <!-- 制作过程 -->

            <LinearLayout
                android:id="@+id/pro_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >
            </LinearLayout>

            <EditText
                android:id="@+id/menu_introduce"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dip"
                android:gravity="top"
                android:hint="简介"
                android:lines="5" />
            <!-- 小技巧 -->

            <EditText
                android:id="@+id/et_kill"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dip"
                android:ems="10"
                android:hint="小技巧"
                android:padding="10dip"
                android:textSize="15sp" />
            <!-- 添加步骤 -->

            <LinearLayout
                android:id="@+id/lay_recipe_upload_add_step"
                android:layout_width="fill_parent"
                android:layout_height="45.0dip"
                android:layout_marginBottom="40.0dip"
                android:layout_marginLeft="10.0dip"
                android:layout_marginRight="10.0dip"
                android:layout_marginTop="15.0dip"
                android:background="@drawable/btn_login"
                android:gravity="center"
                android:orientation="horizontal" >

                <LinearLayout
                    android:id="@+id/add_pro"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" >

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/xiangji" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20.0dip"
                        android:text="添加步骤"
                        android:textColor="#ffffffff" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</LinearLayout>