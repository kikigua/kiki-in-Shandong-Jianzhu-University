<?xml version="1.0" encoding="utf-8"?>
<!-- 菜谱详细信息 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:imagecontrol="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical" >
	<include 
	    android:id="@+id/include_head"
	    android:layout_width="match_parent"
	    android:layout_height="wrap_content"
	    layout="@layout/head_general"/> 					 <!-- 头部信息 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_weight="1" >							<!-- 主界面 -->

        <com.example.MyScrollView.MyRandomScrollView
            android:id="@+id/menu_scrollView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" >			<!-- 主要布局 -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" >
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" >		 <!-- 顶部图片布局 -->	

                    <ImageView
                        android:id="@+id/primary_iv"
                        android:layout_width="match_parent"
                        android:layout_height="300dip"
                        android:layout_marginBottom="50dip"
                        android:scaleType="centerCrop"
                        android:src="@drawable/recipe_defult_img" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="10dip"
                        android:orientation="horizontal" >

                        <com.example.MyRoundedImageView.RoundImageView
                            android:id="@+id/uid_p"
                            android:layout_width="80dip"
                            android:layout_height="80dip"
                            android:scaleType="centerCrop"
                            android:src="@drawable/recipe_defult_img"
                            imagecontrol:border_inside_color="#fff7f2e9"
                            imagecontrol:border_outside_color="#ffd5d1c8"
                            imagecontrol:border_thickness="2dp" />

                        <TextView
                            android:id="@+id/uid_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom"
                            android:layout_marginLeft="5dip"
                            android:text="用户名"
                            android:textSize="20sp" />
                    </LinearLayout>

                    <ToggleButton
                        android:id="@+id/attention"
                        android:layout_width="100dip"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|right"
                        android:layout_margin="5dip"
                        android:background="@drawable/bg_pinglun_atten"
                        android:checked="false"
                        android:gravity="center"
                        android:padding="5dip"
                        android:singleLine="true"
                        android:textColor="@color/red"
                        android:textOff="关注"
                        android:textOn="取消关注"
                        android:textSize="15sp" />
                </FrameLayout>               

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="5dip"
                    android:layout_marginRight="5dip"
                    android:divider="@drawable/item_background"
                    android:orientation="vertical"
                    android:showDividers="middle|end" >				 <!-- 菜品相关信息 -->

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="5dip"
                        android:layout_margin="5dp"
                        android:orientation="vertical" >			 <!-- 菜谱简介 -->

                        <TextView
                            android:id="@+id/menu_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:singleLine="true"
                            android:text="鱼香肉丝"
                            android:textSize="20sp" />				<!-- 菜名 -->

                        <include
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="10dp"
                            layout="@layout/more_or_less" />		<!-- 引入简介 内容布局 -->

                        <LinearLayout
                            android:id="@+id/vice_info"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" >
                        </LinearLayout>
                    </LinearLayout>                   

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="5dp"
                        android:orientation="vertical" >				 <!-- 食材明细总布局-->

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:background="#00000000"
                            android:text="食材明细"
                            android:textSize="20sp" />					<!-- 食材明细标题 -->

                        <LinearLayout
                            android:id="@+id/food_info"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" >
                        </LinearLayout>
                    </LinearLayout>                    

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" 
                        android:layout_margin="5dp">			<!-- 制作步骤总布局 -->

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:text="制作步骤"
                            android:textSize="20sp" />			<!-- 制作步骤标题 -->

                        <LinearLayout
                            android:id="@+id/proces"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical" >
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_margin="5dp" >					<!-- 温馨提示总布局 -->

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="温馨提示"
                            android:layout_margin="5dp"
                            android:textSize="20sp" />				<!-- 温馨提示标题 -->

                        <TextView
                            android:id="@+id/tips"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gray"
                            android:textSize="15sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.example.MyScrollView.MyRandomScrollView>

        <include
            android:id="@+id/buttom_menu_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            layout="@layout/random_bottom_menu" />				<!-- 底部菜单栏 -->
    </FrameLayout>
</LinearLayout>