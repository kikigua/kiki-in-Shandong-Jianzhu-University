<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="#ffffffff" >

    <LinearLayout
        android:layout_width="0.0px"
        android:layout_height="0.0px"
        android:focusable="true"
        android:focusableInTouchMode="true" >

    </LinearLayout>

    <include
        android:id="@+id/include_head"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        layout="@layout/head_general" />

    <TextView
        android:id="@+id/choose_tip_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/choose_tip_input"
        android:layout_centerHorizontal="true"
        android:layout_marginLeft="10.0dip"
        android:layout_marginRight="10.0dip"
        android:ellipsize="end"
        android:gravity="center"
        android:padding="5.0dip"
        android:singleLine="true"
        android:text="@string/please_select_label" />

    <ListView
        android:id="@+id/choose_tip_listview"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/choose_tip_text"
        android:layout_marginTop="10.0dip"
        android:divider="@null"
        android:listSelector="@android:color/transparent" />

    <EditText
        android:id="@+id/choose_tip_input"
        android:layout_width="fill_parent"
        android:layout_height="50.0dip"
        android:layout_below="@+id/include_head"
        android:layout_centerHorizontal="true"
        android:layout_margin="10.0dip"
        android:background="@drawable/search_lay_border"
        android:ems="10"
        android:gravity="center_vertical"
        android:hint="@string/user_defined_label"
        android:padding="5.0dip"
        android:textColor="#ff333333"
        android:textColorHint="#ffb0b0b0" />

</RelativeLayout>